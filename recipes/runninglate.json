{
  "name": "runninglate",
  "description": "Request a WhatsApp running-late message for the trusted driving-mode test channel.",
  "usage": "commandbook runninglate --eta \"10 minutes\"",
  "defaultScope": "driving_mode",
  "goal": {
    "facts": ["runningLateMessage"],
    "effects": ["whatsapp_message_send_requested"]
  },
  "docs": [
    "docs/examples/driving-mode.md"
  ],
  "queue": [
    {
      "op": "prepare_running_late_message",
      "defaults": {
        "contact": "self",
        "channel": "whatsapp",
        "eta": "10 minutes",
        "autoSend": true,
        "testChannel": true
      },
      "outputFact": "runningLateMessage"
    }
  ]
}
