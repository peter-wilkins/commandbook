{
  "name": "git_push_current_branch",
  "description": "Push the current branch, repairing missing git identity inside the current run if that blocks the push.",
  "usage": "commandbook git_push_current_branch --yes",
  "docs": [
    "docs/runtime/reusable-core.md",
    "docs/runtime/operation-patterns.md"
  ],
  "defaultScope": "current_repo",
  "goal": {
    "effects": ["git_branch_pushed"]
  },
  "queue": [
    { "op": "query_current_repo" },
    { "op": "try_git_push_current_branch" },
    { "op": "ask_are_you_happy" }
  ]
}
