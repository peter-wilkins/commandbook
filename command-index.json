      "usage": "commandbook git_push_current_branch --yes",
      "defaultScope": "current_repo",
      "docs": [
        "docs/runtime/reusable-core.md",
        "docs/runtime/operation-patterns.md"
      ],
      "recipePath": "recipes/git_push_current_branch.json",
