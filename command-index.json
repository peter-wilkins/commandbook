    },
    {
      "name": "deepwater",
      "description": "Fetch Portland tide predictions and answer when the water is deep enough for a 0.9m guideline threshold.",
      "usage": "commandbook deepwater --date-path -20260616",
      "defaultScope": "public_tide_read",
      "docs": [
        "Source: https://www.tidetimes.org.uk/portland-tide-times",
        "Guideline only. TideTimes explicitly says its predictions are not for navigation."
      ],
      "recipePath": "recipes/deepwater.json",
      "sha256": "6dcf35a191a9831325d1ee36475a41957a8eeb56b5c4f97a9b596ee32ee0d829"
    },
    {
      "name": "git_push_current_branch",
